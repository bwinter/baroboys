server {
    listen 8080 default_server;
    server_name _;

    # Serve admin panel root (static HTML)
    location = / {
        root /opt/baroboys/static;
        index admin.html;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;

        try_files /admin.html =404;

        limit_except GET {
            deny all;
        }
    }

    # Serve favicon statically
    location = /favicon.ico {
        root /opt/baroboys/static;
    }

    # Proxy all Flask routes (keep this list up to date!)
    location /check-status {
        proxy_pass http://127.0.0.1:5000/check-status;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    location /trigger-shutdown {
        proxy_pass http://127.0.0.1:5000/trigger-shutdown;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
        limit_except POST {
            deny all;
        }
    }

    location /logs/tail/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    location /directory {
        proxy_pass http://127.0.0.1:5000/directory;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    location /ping {
        proxy_pass http://127.0.0.1:5000/ping;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    location /debug-health {
        proxy_pass http://127.0.0.1:5000/debug-health;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    # Catch-all: pass to Flask for unknown paths
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }
}
