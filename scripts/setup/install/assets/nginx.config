server {
    listen 8080 default_server;
    server_name _;

    # Serve favicon statically
    location = /favicon.ico {
        root /opt/baroboys/static;
    }

    # Admin panel static root
    location = / {
        root /opt/baroboys/static;
        index admin.html;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;

        limit_except GET {
            deny all;
        }
    }

    # Auth-protected Flask proxy for all subpaths
    location ~ ^/(check-status|trigger-shutdown|logs/tail/.*|ping|directory)$ {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }
}
