server {
    listen 8080 default_server;
    server_name _;

    # Admin Panel UI
    location = / {
        root /opt/baroboys/static;
        index admin.html;

        auth_basic "Admin Interface";
        auth_basic_user_file /etc/nginx/.htpasswd;

        limit_except GET {
            deny all;
        }
    }

    # Log browser
    location /logs/ {
        alias /home/bwinter_sc81/baroboys/VRising/logs/;
        autoindex on;
        autoindex_exact_size off;
        autoindex_localtime on;

        auth_basic "Restricted Logs";
        auth_basic_user_file /etc/nginx/.htpasswd;

        limit_except GET {
            deny all;
        }
    }

    # Shutdown trigger
    location = /trigger-shutdown {
        proxy_pass http://127.0.0.1:5000/trigger-shutdown;
        proxy_set_header Host $host;

        auth_basic "Protected Trigger";
        auth_basic_user_file /etc/nginx/.htpasswd;

        limit_except POST {
            deny all;
        }
    }
}
