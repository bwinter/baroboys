[Unit]
Description=Xvfb Refresh
Requires=network-online.target refresh-repo-startup.service infrastructure-refresh.service
After=network-online.target refresh-repo-startup.service infrastructure-refresh.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/bwinter_sc81
User=bwinter_sc81

ExecStart=/home/bwinter_sc81/baroboys/scripts/services/xvfb/refresh.sh

SuccessExitStatus=0
KillMode=control-group
TimeoutStartSec=300

StandardOutput=append:/var/log/baroboys/xvfb.log
StandardError=append:/var/log/baroboys/xvfb.log

[Install]
WantedBy=multi-user.target
