[Unit]
Description=Refresh Repo Refresh
Requires=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/root
User=root

ExecStart=/root/baroboys/scripts/services/refresh_repo/refresh.sh

SuccessExitStatus=0
KillMode=control-group
TimeoutStartSec=300

StandardOutput=append:/var/log/baroboys/refresh_repo.log
StandardError=append:/var/log/baroboys/refresh_repo.log

[Install]
WantedBy=multi-user.target
