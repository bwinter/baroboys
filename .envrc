# Canonical source for infrastructure globals used by shell scripts, Make, and local dev tools.
# Terraform/Packer carry the same project/zone/region values in terraform/shared.tfvars
# (they can't source shell). Keep these in sync if values ever change.
export PROJECT="europan-world"
export GCP_USER="bwinter_sc81"
export ZONE="us-west1-c"
export REGION="us-west1"

if [ -f .venv/bin/activate ]; then
  source .venv/bin/activate
else
  echo "⚠️ Missing .venv/bin/activate. Run: python3 -m venv .venv"
fi
